# Include dynamically generated versions list from latest release
$include https://github.com/choco-technologies/dmosi/releases/download/vlatest/versions.dmm

# Module entries with version placeholder - will be expanded by $version-available
# dmosi now ships a precompiled static library alongside its headers, so it is
# architecture-dependent like any other system module (see dmlist, dmheap)
dmosi https://github.com/choco-technologies/dmosi/releases/download/v<version>/dmosi-v<version>-<arch_name>.zip
